# Base URL of the Fastify API, used by the browser for proxied requests
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Internal API URL used by server components / route handlers (server-to-server).
# In docker-compose this is the service name; locally it matches the public URL.
API_INTERNAL_URL="http://localhost:4000"

# Database / Redis / secrets are not required by the web app directly, but are
# included so a single .env can configure the whole stack if desired.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/doc_to_audio?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-to-a-long-random-string"
GEMINI_API_KEY="your-gemini-api-key"
GOOGLE_APPLICATION_CREDENTIALS="./gcp-credentials.json"
