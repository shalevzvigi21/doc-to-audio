# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/doc_to_audio?schema=public"

# Redis connection string used by BullMQ
REDIS_URL="redis://localhost:6379"

# Secret used to sign and verify JWTs (use a long random value in production)
JWT_SECRET="change-me-to-a-long-random-string"

# How long issued JWTs remain valid
JWT_EXPIRES_IN="7d"

# Google Gemini API key (used to clean/segment document text before synthesis)
GEMINI_API_KEY="your-gemini-api-key"

# Path to a Google Cloud service-account JSON with Text-to-Speech access
GOOGLE_APPLICATION_CREDENTIALS="./gcp-credentials.json"

# Azure Speech (optional alternative TTS provider). Set both KEY and REGION to
# enable the "Azure" choice in the UI. Region is the short name, e.g. "westeurope".
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""
# Hebrew neural voice; alternatives: he-IL-HilaNeural (female), he-IL-AvriNeural (male)
AZURE_SPEECH_VOICE="he-IL-AvriNeural"

# Host/port the Fastify server binds to
HOST="0.0.0.0"
PORT="4000"

# Comma-separated list of allowed CORS origins (the web app)
CORS_ORIGIN="http://localhost:3000"

# Directory where uploaded documents and generated audio are stored
UPLOAD_DIR="./uploads"
